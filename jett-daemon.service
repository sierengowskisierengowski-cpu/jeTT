[Unit]
Description=jeTT AI EDR Daemon
After=network.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/jett
Environment=JETT_MODEL=/opt/jett/models/jeTT-q4.gguf
Environment=JETT_BIN=jett
ExecStart=/usr/bin/env jett-daemon
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
